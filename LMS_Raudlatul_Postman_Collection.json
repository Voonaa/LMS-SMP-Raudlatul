							]
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Pengujian Blackbox untuk memastikan validasi kredensial pengguna bekerja dengan baik."
					},
					"response": []
				}
			]
		},
		{
