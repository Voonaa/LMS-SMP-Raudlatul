						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"jawaban\": {\r\n        \"1\": \"A\",\r\n        \"2\": \"B\",\r\n        \"3\": \"C\",\r\n        \"4\": \"D\",\r\n        \"5\": \"A\"\r\n    }\r\n}",
